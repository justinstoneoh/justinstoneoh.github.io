<section id="rankings" class="card">
  <h2>Rankings & Votes</h2>
  <p class="micro">Interactive rankings that update instantly and save in your browser.</p>

  <div class="two-col">
    <!-- Beer Ranking -->
    <div>
      <h3>Beer Ranking</h3>
      <div class="row between">
        <div class="micro" id="beerTotalText">Total votes: 0</div>
        <button class="button secondary small" id="beerResetBtn" type="button">Reset</button>
      </div>
      <div id="beerList" class="vote-list"></div>
    </div>

    <!-- Best Sport Vote -->
    <div>
      <h3>Vote: Best Sport</h3>
      <div class="row between">
        <div class="micro" id="sportTotalText">Total votes: 0</div>
        <button class="button secondary small" id="sportResetBtn" type="button">Reset</button>
      </div>
      <div id="sportList" class="vote-list"></div>
    </div>
  </div>
</section>
